{
  "name": "@polr-software/checkout",
  "version": "0.0.1",
  "description": "One-shot payments kit for TypeScript apps",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "keywords": [
    "checkout",
    "payments",
    "przelewy24",
    "one-time",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polr-software/polr-checkout.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "polr-source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./handlers/next": {
      "polr-source": "./src/handlers/next.ts",
      "types": "./src/handlers/next.ts",
      "default": "./src/handlers/next.ts"
    },
    "./client": {
      "polr-source": "./src/client/index.ts",
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./database": {
      "polr-source": "./src/database/schema.ts",
      "types": "./src/database/schema.ts",
      "default": "./src/database/schema.ts"
    }
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc --build",
    "db:generate": "drizzle-kit generate --config src/database/drizzle.config.ts"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "better-call": "^2.0.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.5",
    "tsdown": "^0.21.1",
    "vitest": "^4.0.18"
  }
}
